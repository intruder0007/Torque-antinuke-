# ============================================================
#  TorqueAntiNuke — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to GitHub.
# ============================================================

# [REQUIRED] Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# [REQUIRED] Your bot's application/client ID
CLIENT_ID=your_client_id_here

# [OPTIONAL] Your bot's OAuth2 client secret (only needed for OAuth flows)
CLIENT_SECRET=your_client_secret_here

# [OPTIONAL] A specific guild ID to deploy slash commands to during development.
# Leave blank to deploy globally (takes up to 1 hour to propagate).
GUILD_ID=your_dev_guild_id_here
